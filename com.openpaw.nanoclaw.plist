<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.openpaw.nanoclaw</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__REPO_DIR__/scripts/nanoclaw-start.sh</string>
	</array>

	<key>WorkingDirectory</key>
	<string>__REPO_DIR__</string>

	<key>RunAtLoad</key>
	<true/>

	<key>KeepAlive</key>
	<true/>

	<key>ThrottleInterval</key>
	<integer>10</integer>

	<key>StandardOutPath</key>
	<string>__HOME_DIR__/.nanoclaw/logs/nanoclaw.stdout.log</string>

	<key>StandardErrorPath</key>
	<string>__HOME_DIR__/.nanoclaw/logs/nanoclaw.stderr.log</string>

	<key>ProcessType</key>
	<string>Background</string>
</dict>
</plist>
